# Client
# Single source of truth for the public origin. Set APP_DOMAIN to your machine's LAN IP
# (ipconfig getifaddr en0) for mobile device access, or leave as localhost. Everything below
# derives from it — change the domain in one place.
APP_DOMAIN=http://localhost
CLIENT_URL=${APP_DOMAIN}:3001
# Public site origin for the SEO surface (sitemap.xml, robots.txt, Open Graph / canonical URLs).
NEXT_PUBLIC_APP_DOMAIN=${CLIENT_URL}
# Internal API port — single source: api container PORT, dev published port, API_URL, WS origin.
# (nginx.conf still references api:3000 literally — it's a static file, can't read env.)
API_PORT=3000
# WebSocket ORIGIN (scheme+host+port). The /ws/room namespace is appended in code.
#   DEV  (this file): API exposed directly on :${API_PORT}.
#   PROD: drop the port — `${APP_DOMAIN}` — nginx proxies /socket.io/ to the api on 443.
NEXT_PUBLIC_WS_ORIGIN=${APP_DOMAIN}:${API_PORT}

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ROOM_MEMBER_INVITE_TOKEN_SECRET=
JWT_ROOM_MEMBER_TOKEN_SECRET=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=172800

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auction-hub-db
DATABASE_URL=postgres://postgres:postgres@db:5432/auction-hub-db

# Email — dev: sign up at https://mailtrap.io for a free sandbox.
# Production (Resend SMTP): user is literally "resend", password is the API key
# (re_...) from https://resend.com/api-keys. Verify the sending domain at
# https://resend.com/domains. Use:
#   EMAIL_HOST=smtp.resend.com
#   EMAIL_PORT=465
#   EMAIL_USER=resend
#   EMAIL_PASSWORD=re_your_api_key
# `secure` is derived from the port automatically (465 = implicit TLS, 587 = STARTTLS).
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=465
# Envelope "From" — must be on a domain verified with the provider (Resend: @auctionshub.net).
EMAIL_FROM="AuctionHub <no-reply@auctionshub.net>"

# Storage
# Values below are DEV (local MinIO, works with docker-compose).
# The trailing comment on each line is the PROD (AWS S3) equivalent.
STORAGE_ENDPOINT=http://minio:9000          # PROD: https://s3.eu-north-1.amazonaws.com
STORAGE_ACCESS_KEY=minioadmin               # PROD: IAM user `auctionhub-app` access key id
STORAGE_SECRET_KEY=minioadmin               # PROD: that user's secret access key
STORAGE_BUCKET=auction-images               # PROD: your globally-unique bucket name
STORAGE_REGION=us-east-1                     # PROD: eu-north-1
STORAGE_PUBLIC_URL=${APP_DOMAIN}:9000     # PROD: CloudFront domain, e.g. https://xxxx.cloudfront.net
# Browser upload target for presigned PUT (uploads go straight to S3, not CloudFront).
STORAGE_UPLOAD_URL=${APP_DOMAIN}:9000     # PROD: https://s3.eu-north-1.amazonaws.com
# Path-style addressing: true for MinIO, false for AWS S3 (virtual-hosted).
STORAGE_FORCE_PATH_STYLE=true                # PROD: false

# Google OAuth — Web Client ID from Google Cloud Console (no client secret needed for GIS flow).
# Used by both the Next.js client (NEXT_PUBLIC_ prefix is required by Next to expose to the browser)
# and the Nest server (which reads the same variable for ID-token verification).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# CI/CD — ECR registry for prebuilt prod images (PROD only; not used in dev).
# Format: <account-id>.dkr.ecr.eu-north-1.amazonaws.com
# IMAGE_TAG is injected per-deploy by scripts/deploy.sh (defaults to "latest").
ECR_REGISTRY=

# S3 bucket name (no s3:// prefix) for nightly DB backups — see scripts/backup-db.sh.
BACKUP_BUCKET=
